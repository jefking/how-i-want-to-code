# Optional env-only startup. Preferred flow is templates/init.example.json.
GITHUB_TOKEN=ghp_replace_with_your_token
OPENAI_API_KEY=sk_replace_with_your_key

# Optional when no init.json/config.json is mounted and with-config must auto-create init.
MOLTEN_HUB_TOKEN=agent_or_bind_token_here
MOLTEN_HUB_URL=https://na.hub.molten.bot/v1
